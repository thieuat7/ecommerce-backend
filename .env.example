# Application
NODE_ENV=production
PORT=3000

# Database Configuration
DB_HOST=postgres
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=ecommerce

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE_IN=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_change_in_production
JWT_REFRESH_EXPIRE_IN=7d

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:5054

# Momo Payment (if applicable)
MOMO_PARTNER_CODE=MOMOXXXXXX
MOMO_ACCESS_KEY=XXXXXXXXXXX
MOMO_SECRET_KEY=XXXXXXXXXXXXX
